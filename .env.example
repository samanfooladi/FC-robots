# ┌─────────────────────────────────────────────────────────────────────────┐
# │  FC Bot — environment configuration template                            │
# │  Copy this file to .env and fill in your values.                        │
# │  Never commit .env to version control.                                  │
# └─────────────────────────────────────────────────────────────────────────┘

# ── Telegram ──────────────────────────────────────────────────────────────────
# Bot token from @BotFather
TELEGRAM_BOT_TOKEN=

# Comma-separated Telegram user IDs who are admins
# Get your ID by messaging @userinfobot on Telegram
ADMIN_IDS=

# ── EA Accounts ───────────────────────────────────────────────────────────────
# EA account credentials are NOT configured here anymore.
# Add accounts from Telegram with /addaccount — the bot asks for the email,
# password, and 2FA backup code step by step and stores them in the database.

# ── Database ──────────────────────────────────────────────────────────────────
# Path to the SQLite database file (created automatically on first run)
DB_PATH=data/fc_bot.db

# ── Logging ───────────────────────────────────────────────────────────────────
# One of: DEBUG, INFO, WARNING, ERROR  (default: INFO)
LOG_LEVEL=INFO

# ── Browser pool ──────────────────────────────────────────────────────────────
# Where persistent Chrome profiles are stored (one folder per EA account)
PROFILES_DIR=data/profiles
# true = run browsers hidden; false = show browser windows (default: false —
# keep visible until the backup-code login flow has been verified live)
BROWSER_HEADLESS=false
# Seconds between browser health checks (default: 300)
BROWSER_HEALTH_CHECK_INTERVAL_S=300

# ── Player names ──────────────────────────────────────────────────────────────
# The Transfer Market API returns no player names — they are resolved from EA's
# players.json. EA's CDN is bot-protected, so a server-side download often fails
# and names fall back to the configured card name (e.g. "Rare Gold 80-81").
# Reliable fix: open the web app in a browser, find the players.json request in
# DevTools → Network, save it, and point PLAYERS_JSON_FILE at the saved file
# (or just drop it at market/players.json — picked up automatically).
# PLAYERS_JSON_FILE=market/players.json
# Optional: the exact CDN URL from the Network tab (only works if this host is
# not blocked by EA).
# PLAYERS_JSON_URL=

# ── Bot Behaviour ─────────────────────────────────────────────────────────────
# Human-like delay range between HTTP requests in seconds (default: 0.5–2.0)
REQUEST_DELAY_MIN=0.5
REQUEST_DELAY_MAX=2.0

# ── DSFUT (browser automation) ────────────────────────────────────────────────
# The poller drives the dsfut.net website to pick up console orders. The first
# login/captcha is solved manually in the Chromium window; the session persists
# in the profile directory below, so it is normally only needed once.
DSFUT_ENABLED=true
# Comfort-trade order board — polled for pickable orders; a claimed order goes
# to /comfortable/active, then the poller returns here to hunt for the next one.
DSFUT_BOARD_URL=https://dsfut.net/comfortable
# Persistent Chromium profile directory (keep under data/ so it is gitignored)
DSFUT_BROWSER_PROFILE_DIR=data/dsfut_profile
# Keep false so the login captcha is visible; set true only after login when
# you don't need to watch the window.
DSFUT_BROWSER_HEADLESS=false
# Fast HTTP poll cadence for /api/json/comfortables (competitive; ~0.1s)
DSFUT_POLL_INTERVAL_S=0.1
# Per-request HTTP timeout (seconds) for the fast loop
DSFUT_HTTP_TIMEOUT_S=15
# Account's DSFUT order cap in coins — CUMULATIVE over orders still active
# ("The amount exceeds the maximum allowed" otherwise). Orders that would go
# over are skipped instead of attempted. 0 = no pre-filter. Ask the DSFUT
# manager for the exact cap.
DSFUT_MAX_ACTIVE_COINS=0
