# ┌─────────────────────────────────────────────────────────────────────────┐
# │  FC Bot — environment configuration template                            │
# │  Copy this file to .env and fill in your values.                        │
# │  Never commit .env to version control.                                  │
# └─────────────────────────────────────────────────────────────────────────┘

# ── Telegram ──────────────────────────────────────────────────────────────────
# Bot token from @BotFather
TELEGRAM_BOT_TOKEN=

# Comma-separated Telegram user IDs who are admins
# Get your ID by messaging @userinfobot on Telegram
ADMIN_IDS=

# ── EA Account Pool ───────────────────────────────────────────────────────────
# Add EA_ACCOUNT_N_* triplets (N = 1, 2, 3 …) for each EA account in the pool.
# Each account handles up to MAX_CLIENTS_PER_ACCOUNT clients.
# The bot auto-detects how many accounts are configured.

EA_ACCOUNT_1_EMAIL=
EA_ACCOUNT_1_PASSWORD=
# Base-32 TOTP secret shown during EA 2FA setup (no spaces, no dashes)
# Example: JBSWY3DPEHPK3PXP
EA_ACCOUNT_1_OTP_KEY=

# EA_ACCOUNT_2_EMAIL=account2@example.com
# EA_ACCOUNT_2_PASSWORD=your_ea_password_here
# EA_ACCOUNT_2_OTP_KEY=BASE32ENCODEDOTPKEYHERE

# ── Database ──────────────────────────────────────────────────────────────────
# Path to the SQLite database file (created automatically on first run)
DB_PATH=data/fc_bot.db

# ── Logging ───────────────────────────────────────────────────────────────────
# One of: DEBUG, INFO, WARNING, ERROR  (default: INFO)
LOG_LEVEL=INFO

# ── Bot Behaviour ─────────────────────────────────────────────────────────────
# Maximum number of clients assignable to a single EA account (default: 5)
MAX_CLIENTS_PER_ACCOUNT=5

# Human-like delay range between HTTP requests in seconds (default: 0.5–2.0)
REQUEST_DELAY_MIN=0.5
REQUEST_DELAY_MAX=2.0
